/* pages/mine/mine.wxss */
.mine-container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 120rpx;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx 80rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background: #fff;
}

.user-detail {
  margin-left: 30rpx;
  flex: 1;
}

.nickname {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.user-id {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

.login-tip {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* 菜单区域 */
.menu-section {
  margin: 30rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8f8f8;
}

.menu-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.favorites-icon {
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
}

.history-icon {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.feedback-icon {
  background: linear-gradient(135deg, #d299c2 0%, #fef9d7 100%);
}

.icon-text {
  font-size: 28rpx;
}

.menu-title {
  flex: 1;
  margin-left: 24rpx;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 使用次数 */
.usage-section {
  margin: 0 30rpx 30rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.usage-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.usage-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.usage-limit {
  font-size: 22rpx;
  color: #999;
}

.usage-item {
  margin-bottom: 24rpx;
}

.usage-item:last-of-type {
  margin-bottom: 0;
}

.usage-item-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.usage-item-name {
  font-size: 26rpx;
  color: #555;
}

.usage-item-count {
  font-size: 24rpx;
  color: #888;
}

.usage-bar {
  height: 10rpx;
  background: #f0f0f0;
  border-radius: 5rpx;
  overflow: hidden;
}

.usage-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 5rpx;
  transition: width 0.3s;
}

.usage-bar-fill.full {
  background: linear-gradient(90deg, #ff6b6b 0%, #ee5a24 100%);
}

.usage-tip {
  margin-top: 24rpx;
  padding: 16rpx 20rpx;
  background: #f8f6ff;
  border-radius: 12rpx;
}

.usage-tip-text {
  font-size: 22rpx;
  color: #764ba2;
  line-height: 1.6;
}

/* 白名单已解锁横幅 */
.whitelist-banner {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
  border-radius: 16rpx;
}

.whitelist-icon {
  font-size: 40rpx;
  color: #fff;
  margin-right: 20rpx;
}

.whitelist-info {
  display: flex;
  flex-direction: column;
}

.whitelist-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.whitelist-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 6rpx;
}

/* 退出登录 */
.logout-section {
  margin: 60rpx 30rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #ff4d4f;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-btn::after {
  border: none;
}

/* 底部版权 */
.footer {
  padding: 40rpx;
  text-align: center;
}

.copyright {
  display: block;
  font-size: 22rpx;
  color: #999;
  line-height: 1.8;
}

/* 登录弹窗 */
.login-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.login-modal-content {
  position: relative;
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.login-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 0;
}

.login-modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.login-modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

.login-modal-body {
  padding: 40rpx 32rpx 48rpx;
}

.login-modal-tip {
  display: block;
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.login-modal-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-modal-btn.loading {
  opacity: 0.7;
}

.login-modal-btn::after {
  border: none;
}
