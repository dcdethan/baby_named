/* pages/home/home.wxss */
.home-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9ff 0%, #f0f2f8 100%);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 顶部标题区域 */
.header {
  padding: 80rpx 40rpx 60rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 72rpx;
  font-weight: 800;
  color: #333;
  letter-spacing: 8rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #888;
  margin-top: 16rpx;
  letter-spacing: 2rpx;
}

/* 功能卡片区域 */
.feature-section {
  padding: 20rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.feature-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(102, 126, 234, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s ease;
}

.feature-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.12);
}

/* 图标区域 */
.card-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 28rpx;
}

.naming-icon {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.analysis-icon {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.library-icon {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.icon-main {
  font-size: 56rpx;
  color: #fff;
}

.icon-sub {
  position: absolute;
  right: 16rpx;
  top: 16rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 卡片标题 */
.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

/* 卡片描述 */
.card-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}
