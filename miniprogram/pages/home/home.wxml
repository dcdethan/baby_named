<!-- pages/home/home.wxml -->
<view class="home-container">
  <!-- 顶部标题区域 -->
  <view class="header">
    <text class="title">起名宝典</text>
    <text class="subtitle">好名伴一生，我来帮你选</text>
  </view>

  <!-- 核心功能卡片区域 -->
  <view class="feature-section">
    <!-- 智慧起名 -->
    <view class="feature-card" bindtap="goToNaming">
      <view class="card-icon naming-icon">
        <text class="icon-main">✐</text>
        <text class="icon-sub">✦</text>
      </view>
      <view class="card-title">智慧起名</view>
      <view class="card-desc">一键生成，风格任选</view>
    </view>

    <!-- 名字分析 -->
    <view class="feature-card" bindtap="goToAnalysis">
      <view class="card-icon analysis-icon">
        <text class="icon-main">🔍</text>
        <text class="icon-sub">文</text>
      </view>
      <view class="card-title">名字分析</view>
      <view class="card-desc">多维度解析，读懂名字深意</view>
    </view>

    <!-- 起名字库 -->
    <view class="feature-card" bindtap="goToLibrary">
      <view class="card-icon library-icon">
        <text class="icon-main">📖</text>
        <text class="icon-sub">✎</text>
      </view>
      <view class="card-title">起名字库</view>
      <view class="card-desc">分类查询，精准选字</view>
    </view>
  </view>
</view>
