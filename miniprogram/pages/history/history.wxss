/* pages/history/history.wxss */
.history-container {
  min-height: 100vh;
  background: #f5f6fa;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #667eea;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 2rpx;
}

.tab-count {
  margin-left: 8rpx;
  font-size: 24rpx;
}

/* 清空按钮栏 */
.clear-bar {
  display: flex;
  justify-content: flex-end;
  padding: 20rpx 30rpx;
  background: #fff;
}

.clear-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #fff0f0;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #ff4d4f;
}

.clear-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

/* 列表区域 */
.list-section {
  padding: 30rpx;
}

/* 历史记录卡片 */
.history-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.history-card:active {
  opacity: 0.9;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.surname {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.fullname {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.card-body {
  margin-bottom: 20rpx;
}

.info-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.info-tag {
  padding: 6rpx 16rpx;
  background: #f5f6fa;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #666;
}

.names-preview {
  display: flex;
  align-items: flex-start;
}

.preview-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

.preview-names {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
  flex: 1;
}

/* 分析记录特有样式 */
.score-section {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.score-label {
  font-size: 26rpx;
  color: #999;
}

.score-value {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 600;
  margin-left: 8rpx;
}

.analysis-preview {
  margin-top: 12rpx;
}

.preview-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-footer {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.view-btn {
  font-size: 26rpx;
  color: #667eea;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  color: #ddd;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #999;
}

.empty-tip {
  display: block;
  font-size: 26rpx;
  color: #bbb;
  margin-top: 12rpx;
}

.go-btn {
  display: inline-block;
  margin-top: 40rpx;
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* 加载更多 */
.loading-more, .no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #999;
}
