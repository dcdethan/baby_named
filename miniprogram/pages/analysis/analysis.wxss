/* pages/analysis/analysis.wxss */
.analysis-container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 180rpx;
}

/* 输入区域 */
.input-section {
  padding: 30rpx;
  background: #fff;
}

.input-group {
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.name-input {
  height: 88rpx;
  background: #f5f6fa;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 32rpx;
}

.name-input::placeholder {
  color: #bbb;
}

/* 性别选择 */
.gender-section {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.gender-label {
  font-size: 28rpx;
  color: #333;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.gender-options {
  display: flex;
  gap: 16rpx;
}

.gender-btn {
  width: 100rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  background: #f5f6fa;
  font-size: 24rpx;
  color: #666;
  border-radius: 26rpx;
}

.gender-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 生日开关 */
.birthday-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.toggle-left {
  display: flex;
  align-items: center;
}

.toggle-label {
  font-size: 28rpx;
  color: #333;
}

.toggle-hint {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

/* 生日选择器 */
.birthday-picker {
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.picker-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.picker-label {
  font-size: 28rpx;
  color: #666;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
  padding: 12rpx 24rpx;
  background: #f5f6fa;
  border-radius: 12rpx;
}

.picker-value.placeholder {
  color: #bbb;
}

/* 分析按钮 */
.analyze-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 30rpx;
}

.analyze-btn::after {
  border: none;
}

.analyze-btn.loading {
  opacity: 0.7;
}

/* 结果区域 */
.result-section {
  padding: 30rpx;
}

.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 基础信息 */
.info-list {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.info-analysis {
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
  border-radius: 16rpx;
}

.analysis-label {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.analysis-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 字义内涵 */
.char-meanings {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.char-meaning-item {
  padding: 24rpx;
  background: #f8f9ff;
  border-radius: 16rpx;
}

.char-header {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.char-gender-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  margin-left: auto;
}

.char-gender-tag.fit {
  background: rgba(82, 196, 26, 0.15);
  color: #52c41a;
}

.char-gender-tag.normal {
  background: rgba(250, 173, 20, 0.15);
  color: #faad14;
}

.char-gender-tag.unfit {
  background: rgba(255, 77, 79, 0.15);
  color: #ff4d4f;
}

.char-gender-warning {
  margin-top: 16rpx;
  padding: 16rpx;
  background: rgba(255, 77, 79, 0.08);
  border-radius: 12rpx;
  border-left: 4rpx solid #ff4d4f;
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.warning-icon {
  color: #ff4d4f;
  font-size: 28rpx;
  flex-shrink: 0;
}

.warning-text {
  font-size: 26rpx;
  color: #ff4d4f;
  line-height: 1.6;
}

.char-big {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.char-pinyin {
  font-size: 26rpx;
  color: #667eea;
}

.char-meaning-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.combined-meaning {
  margin-top: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
  border-radius: 16rpx;
}

.meaning-label {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.meaning-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
}

/* 文化背景 */
.content-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 性别适配分析 */
.gender-analysis-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.suitability-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.suitability-label {
  font-size: 28rpx;
  color: #666;
}

.suitability-tag {
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.suitability-tag.good {
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.15) 0%, rgba(115, 209, 61, 0.15) 100%);
  color: #52c41a;
}

.suitability-tag.normal {
  background: rgba(250, 173, 20, 0.15);
  color: #faad14;
}

.suitability-tag.bad {
  background: rgba(255, 77, 79, 0.15);
  color: #ff4d4f;
}

.gender-analysis-content {
  padding: 20rpx;
  background: #f8f9ff;
  border-radius: 12rpx;
}

.gender-analysis-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.gender-suggestions {
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
  border-radius: 12rpx;
}

.gender-suggestions-label {
  display: block;
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.gender-suggestions-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 五行数理 */
.wuxing-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.wuxing-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.wuxing-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.wuxing-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.wuxing-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.wuxing-tag {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
}

/* 流行趋势 */
.popularity-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.popularity-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.pop-char {
  width: 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.pop-bar-wrapper {
  flex: 1;
  height: 24rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
}

.pop-bar {
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  transition: width 0.3s ease;
}

.pop-level {
  width: 80rpx;
  font-size: 24rpx;
  color: #999;
  text-align: right;
}

.duplicate-rate {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #fff8e6;
  border-radius: 12rpx;
  margin-top: 12rpx;
}

.dup-label {
  font-size: 28rpx;
  color: #666;
}

.dup-value {
  font-size: 28rpx;
  color: #f5a623;
  font-weight: 500;
}

/* 适配和优化建议 */
.suggestion-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.suggestion-item {
  padding: 20rpx;
  background: #f5f6fa;
  border-radius: 16rpx;
}

.sug-label {
  display: block;
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.sug-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 30rpx;
  border: none;
}

.action-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
}

.favorite-btn {
  background: #f5f6fa;
  color: #666;
}

.favorite-btn.active {
  background: #fff3cd;
  color: #f5a623;
}

.share-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 登录弹窗 */
.login-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.login-modal-content {
  position: relative;
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.login-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 0;
}

.login-modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.login-modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

.login-modal-body {
  padding: 40rpx 32rpx 48rpx;
}

.login-modal-tip {
  display: block;
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.login-modal-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-modal-btn.loading {
  opacity: 0.7;
}

.login-modal-btn::after {
  border: none;
}
