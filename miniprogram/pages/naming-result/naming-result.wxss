/* pages/naming-result/naming-result.wxss */
.result-container {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 30rpx;
  padding-bottom: 180rpx;
}

/* 五行八字分析卡片 */
.bazi-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
}

/* 四柱表格 */
.bazi-table {
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.bazi-table-row {
  display: flex;
}

.bazi-table-cell {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  border-right: 2rpx solid #e8e8e8;
}

.bazi-table-cell:last-child {
  border-right: none;
}

.bazi-table-header {
  background: #f8f9ff;
  border-bottom: 2rpx solid #e8e8e8;
}

.bazi-table-header .bazi-table-cell {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.bazi-table-ganzhi {
  background: #fff;
  border-bottom: 2rpx solid #e8e8e8;
}

.bazi-table-ganzhi .bazi-table-cell {
  font-size: 34rpx;
  font-weight: 600;
  color: #667eea;
  padding: 20rpx 8rpx;
}

.bazi-table-wuxing {
  background: #fafafa;
}

.bazi-table-wuxing .bazi-table-cell {
  font-size: 24rpx;
  color: #888;
  padding: 14rpx 8rpx;
}

/* 五行结果 */
.bazi-result {
  text-align: center;
  margin-bottom: 24rpx;
  padding: 16rpx 0;
  border-top: 2rpx dashed #e8e8e8;
  border-bottom: 2rpx dashed #e8e8e8;
}

.result-tag {
  display: inline-block;
  padding: 10rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 24rpx;
}

/* 分析区块 */
.bazi-section {
  margin-bottom: 20rpx;
}

.bazi-section:last-child {
  margin-bottom: 0;
}

.bazi-section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #667eea;
}

.bazi-section-content {
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  overflow: hidden;
}

.bazi-explanation {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  padding: 20rpx;
  background: #f8f9ff;
}

.bazi-suggestion {
  font-size: 26rpx;
  color: #e67e22;
  line-height: 1.8;
  padding: 20rpx;
  background: #fff8f0;
}

/* 姓名方案 */
.names-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.name-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.name-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.name-main {
  flex: 1;
}

.full-name {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

.pinyin {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 操作按钮区 */
.name-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.action-icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  background: #f5f6fa;
  border-radius: 32rpx;
  transition: all 0.2s;
}

.action-icon-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.action-icon-btn.active .action-text {
  color: #fff;
}

.action-text {
  font-size: 26rpx;
  color: #666;
}

.action-icon-btn.favorite {
  background: transparent;
  padding: 12rpx;
}

.action-icon-btn.favorite .star {
  font-size: 48rpx;
  color: #ddd;
}

.action-icon-btn.favorite.active .star {
  color: #ffc107;
}

/* 解析面板 */
.analysis-panel {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* 寓意解析区块 */
.char-analysis-section {
  margin-bottom: 24rpx;
}

.analysis-section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #667eea;
}

.char-analysis-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.char-analysis-item {
  display: flex;
  align-items: flex-start;
  background: #f8f9ff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.char-highlight {
  flex-shrink: 0;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.char-big {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.char-meaning {
  flex: 1;
  display: flex;
  align-items: center;
}

.meaning-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
}

/* 整体寓意 */
.overall-meaning {
  margin-top: 16rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
  border-radius: 12rpx;
}

.overall-label {
  display: block;
  font-size: 24rpx;
  color: #667eea;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.overall-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
}

/* 五行数理区块 */
.wuxing-analysis-section {
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: #fafbfc;
  border-radius: 16rpx;
}

.wuxing-chars {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx dashed #e8e8e8;
}

.wuxing-char-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.wuxing-char {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.wuxing-element {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  color: #fff;
}

.wuxing-jin { background: #d4af37; }
.wuxing-mu { background: #4caf50; }
.wuxing-shui { background: #2196f3; }
.wuxing-huo { background: #f44336; }
.wuxing-tu { background: #795548; }

.wuxing-strokes {
  font-size: 22rpx;
  color: #999;
}

/* AI五行分析 */
.wuxing-ai-analysis {
  margin-bottom: 16rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
  border-radius: 12rpx;
}

.wuxing-ai-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
}

/* 五行配置 */
.wuxing-config {
  margin-bottom: 16rpx;
}

.config-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.config-row:last-child {
  border-bottom: none;
}

.config-label {
  font-size: 26rpx;
  color: #666;
}

.config-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.config-value.match {
  color: #4caf50;
}

/* 笔画数理 */
.stroke-analysis {
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.stroke-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}

.stroke-label {
  font-size: 26rpx;
  color: #666;
}

.stroke-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.stroke-rating {
  color: #e67e22;
}

/* 综合评分 */
.score-section {
  display: flex;
  align-items: baseline;
  justify-content: center;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border-radius: 12rpx;
}

.score-section .score-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
}

.score-section .score-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
}

.score-section .score-unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.action-btn::after {
  border: none;
}

.refresh-btn {
  background: #f5f6fa;
  color: #666;
}

.refresh-btn.loading {
  opacity: 0.7;
}

.style-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 风格选择器（下拉列表） */
.style-picker-wrapper {
  flex: 1;
}

/* 登录弹窗 */
.login-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.login-modal-content {
  position: relative;
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.login-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 0;
}

.login-modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.login-modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

.login-modal-body {
  padding: 40rpx 32rpx 48rpx;
}

.login-modal-tip {
  display: block;
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.login-modal-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-modal-btn.loading {
  opacity: 0.7;
}

.login-modal-btn::after {
  border: none;
}
